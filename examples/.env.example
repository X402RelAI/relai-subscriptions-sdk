# Copy to .env and fill in. .env is gitignored.

# Subscriber side (subscribe.ts) — path to a funded Solana keypair JSON (byte array),
# with a little SOL + the plan's token (devnet USDC for a devnet plan).
SUBSCRIBER_KEYPAIR=./subscriber-keypair.json
SUBSCRIPTIONS_RPC_URL=https://api.devnet.solana.com
RELAI_PLAN_ID=

# RelAI API base (default https://api.relai.fi).
RELAI_BASE_URL=https://api.relai.fi

# Merchant side (express-server.ts)
RELAI_KEY=
MERCHANT_WALLET=
RELAI_WEBHOOK_SECRET=
